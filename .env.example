# Copy this file to .env and fill in real values.
# Used by docker-compose.yml.

# Database credentials (used by both postgres container and backend)
DB_USERNAME=pilot
DB_PASSWORD=pilot_password

# JWT secret: must be Base64-encoded, at least 32 bytes
# Generate with: openssl rand -base64 32
JWT_SECRET=

# api-ninjas.com API key for airport data
# Get a free key at https://api.api-ninjas.com/profile
# For DHBW-Project: API Key is send via email
AIRPORT_API_KEY=